# Copy to .env for local dev.
# Load with: set -a && source .env && set +a

DATABRICKS_CATALOG=hls_omop_dev
DATABRICKS_OMOP_SCHEMA=omop531
DATABRICKS_WAREHOUSE_ID=1234567890abcdef

# Auth — any one works; SDK picks them up automatically.
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://adb-xxx.xx.azuredatabricks.net
# DATABRICKS_TOKEN=dapiXXXX

# Optional
DATABRICKS_APP_PORT=7860
LOG_LEVEL=INFO
