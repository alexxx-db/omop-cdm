# Copy to .env and fill in. Load with `set -a && source .env && set +a`
# or run via `uvicorn` with an env-file-aware launcher.

# Required: target UC + warehouse
DATABRICKS_CATALOG=hls_omop_dev
DATABRICKS_OMOP_SCHEMA=omop531
DATABRICKS_WAREHOUSE_ID=1234567890abcdef

# Databricks auth — any one works; SDK picks them up automatically.
# (A) Profile from ~/.databrickscfg
DATABRICKS_CONFIG_PROFILE=DEFAULT
# (B) ...or explicit host + token
# DATABRICKS_HOST=https://adb-xxx.xx.azuredatabricks.net
# DATABRICKS_TOKEN=dapiXXXX

# Optional
LOG_LEVEL=INFO
